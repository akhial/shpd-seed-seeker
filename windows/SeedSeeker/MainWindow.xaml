<Window
    x:Class="SeedSeeker.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SeedSeeker"
    Title="Seed Seeker">
  <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Grid.RowDefinitions><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <Grid ColumnSpacing="0">
      <Grid.ColumnDefinitions><ColumnDefinition Width="330" MinWidth="300"/><ColumnDefinition Width="5"/><ColumnDefinition Width="*" MinWidth="340"/><ColumnDefinition Width="5"/><ColumnDefinition Width="1.08*" MinWidth="360"/></Grid.ColumnDefinitions>

      <Grid Grid.Column="0">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Grid Padding="16,13,12,9"><TextBlock Text="Query" Style="{StaticResource TitleTextBlockStyle}"/><Button Content="Challenges" HorizontalAlignment="Right" Click="Challenges_Click"/></Grid>
        <ScrollViewer Grid.Row="1"><StackPanel Padding="16,0,16,16">
          <TextBlock Text="Requirements" Style="{StaticResource SectionHeader}"/>
          <ItemsRepeater x:Name="RequirementList"><ItemsRepeater.ItemTemplate><DataTemplate>
            <Grid Padding="8" Margin="0,0,0,4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="7" Tapped="Requirement_Tapped">
              <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
              <StackPanel><TextBlock Text="{Binding Title}"/><TextBlock Text="{Binding Description}" Style="{StaticResource Caption}"/></StackPanel>
              <Button Grid.Column="1" Content="&#xE711;" FontFamily="Segoe Fluent Icons" Background="Transparent" Tag="{Binding}" Click="RemoveRequirement_Click" Tapped="RemoveRequirement_Tapped" ToolTipService.ToolTip="Remove requirement"/>
            </Grid>
          </DataTemplate></ItemsRepeater.ItemTemplate></ItemsRepeater>
          <TextBlock x:Name="NoRequirements" Text="No requirements yet. Add one to describe the item you're hunting for." Style="{StaticResource Caption}" Margin="8"/>
          <Button Content="&#xE710;  Add Requirement" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="AddRequirement_Click"/>
          <TextBlock Text="Search scope" Style="{StaticResource SectionHeader}"/>
          <Grid><TextBlock Text="Floor limit"/><TextBlock x:Name="FloorLabel" HorizontalAlignment="Right" Style="{StaticResource Caption}"/></Grid>
          <Slider x:Name="FloorSlider" Maximum="24" StepFrequency="1" ValueChanged="FloorSlider_ValueChanged"/>
          <TextBlock Text="Blacksmith" Style="{StaticResource SectionHeader}"/>
          <CheckBox x:Name="RequireBlacksmith" Content="Require accessible blacksmith" Click="SettingChanged"/>
          <CheckBox x:Name="ExcludeRewards" Content="Exclude Smith rewards" Click="SettingChanged"/>
          <TextBlock Text="Required items cannot come from the 2,000-favor Smith choice, leaving favor available for reforging." Style="{StaticResource Caption}" Margin="32,0,0,0"/>
          <TextBlock Text="Performance" Style="{StaticResource SectionHeader}"/>
          <CheckBox x:Name="FastMode" Content="Fast search" Click="SettingChanged"/>
          <TextBlock Text="Treats +3 weapons and armor as quest rewards only, skipping rare Crypt and Sacrificial-fire prizes. Found seeds are always genuine." Style="{StaticResource Caption}" Margin="32,0,0,0"/>
        </StackPanel></ScrollViewer>
        <StackPanel Grid.Row="2" Padding="16,10,16,16" BorderThickness="0,1,0,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
          <TextBlock x:Name="ChallengeSummary" Style="{StaticResource Caption}" Margin="0,0,0,7" Visibility="Collapsed"/>
          <Button x:Name="StartButton" Content="&#xE768;  Start Search" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Click="Start_Click"/>
        </StackPanel>
      </Grid>
      <Border Grid.Column="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

      <Grid Grid.Column="2" Padding="16,13,16,0">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition/></Grid.RowDefinitions>
        <TextBlock Text="Results" Style="{StaticResource TitleTextBlockStyle}"/>
        <TextBlock x:Name="SearchStatus" Grid.Row="1" Text="Add requirements, then press Start Search." Style="{StaticResource Caption}" Margin="0,10,0,10"/>
        <ListView x:Name="ResultsList" Grid.Row="2" SelectionChanged="ResultsList_SelectionChanged" DoubleTapped="ResultsList_DoubleTapped">
          <ListView.Header><Grid Padding="12,7"><Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Text="#" Style="{StaticResource Caption}"/><TextBlock Grid.Column="1" Text="Seed" FontWeight="SemiBold"/></Grid></ListView.Header>
          <ListView.ItemTemplate><DataTemplate><Grid Padding="4"><Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Text="{Binding Number}" Style="{StaticResource Caption}"/><TextBlock Grid.Column="1" Text="{Binding Seed}" FontFamily="Cascadia Mono"/></Grid></DataTemplate></ListView.ItemTemplate>
        </ListView>
      </Grid>
      <Border Grid.Column="3" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

      <Grid Grid.Column="4">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition/></Grid.RowDefinitions>
        <TextBlock Text="Seed Detail" Style="{StaticResource TitleTextBlockStyle}" Margin="16,13,16,0"/>
        <StackPanel Grid.Row="1" Padding="16,10,16,10" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
          <Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBox x:Name="SeedInput" PlaceholderText="AAA-AAA-AAA" FontFamily="Cascadia Mono, Consolas" FontSize="19" TextChanged="SeedInput_TextChanged" KeyDown="SeedInput_KeyDown"/>
            <Button Grid.Column="1" x:Name="ScoutButton" Content="Scout" Click="Scout_Click"/><Button Grid.Column="2" Content="Copy" Click="CopySeed_Click"/>
          </Grid>
          <TextBlock x:Name="ScoutStatus" Style="{StaticResource Caption}" Margin="0,6,0,0"/>
        </StackPanel>
        <Grid Grid.Row="2"><TextBlock x:Name="EmptyScout" Text="No seed scouted&#x0a;&#x0a;Enter a canonical seed, or select a search result, to inspect its item manifest." TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource Caption}" MaxWidth="300"/>
          <ListView x:Name="ScoutList" Visibility="Collapsed"><ListView.ItemTemplate><DataTemplate><Grid Padding="4,6"><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><FontIcon Glyph="{Binding Glyph}" FontFamily="Segoe Fluent Icons" Foreground="{Binding Tint}"/><StackPanel Grid.Column="1"><StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Text="{Binding ItemName}" FontWeight="{Binding Weight}"/><TextBlock Text="{Binding Upgrade}" Foreground="{ThemeResource SystemFillColorSuccessBrush}" FontWeight="SemiBold"/><TextBlock Text="{Binding Curse}" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/></StackPanel><TextBlock Text="{Binding Detail}" Style="{StaticResource Caption}"/><TextBlock Text="{Binding Accessibility}" Style="{StaticResource Caption}"/></StackPanel><TextBlock Grid.Column="2" Text="{Binding Match}" Foreground="{ThemeResource SystemFillColorSuccessBrush}" FontWeight="SemiBold"/></Grid></DataTemplate></ListView.ItemTemplate></ListView>
        </Grid>
      </Grid>
    </Grid>
    <TextBlock Grid.Row="1" Text="Shattered Pixel Dungeon v3.3.8" HorizontalAlignment="Center" Style="{StaticResource Caption}" Margin="5"/>
  </Grid>
</Window>
